{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "outDir": "dist-electron",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "preserve",
    "isolatedModules": false,
    "rootDir": "src",
    "types": ["node"]
  },
  "include": ["src/main/**/*", "src/shared/**/*"]
}
