{
  "name": "banque-desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/main/package.json',JSON.stringify({type:'commonjs'}))\" && node -e \"require('fs').cpSync('src/main/db/schema.sql','dist-electron/main/db/schema.sql')\" && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/main/package.json',JSON.stringify({type:'commonjs'}))\" && node -e \"require('fs').cpSync('src/main/db/schema.sql','dist-electron/main/db/schema.sql')\"",
    "build": "npm run build:electron && npm run build:vite"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.445.0",
    "nodemailer": "^6.9.15",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.2",
    "better-sqlite3": "^11.3.0",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/better-sqlite3": "^7.6.11",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.7",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.banque.desktop",
    "productName": "Banque Desktop",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    }
  }
}
